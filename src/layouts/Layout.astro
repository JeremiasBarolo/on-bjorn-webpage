---
import Header from '../components/shared/Header.astro'
import Footer from '../components/shared/Footer.astro'
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="ON Bjorn — Desarrollo web, e-commerce y rebranding para potenciar tu emprendimiento online." />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#111022" />
		<link rel="icon" href="/images/resource/ON_BJORN_ISO.png" type="image/png" />
		<meta name="generator" content={Astro.generator} />
		<title>ON BJORN - Potencia tu Emprendimiento</title>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">

		<link href="/css/color-themes/default-color.css" rel="stylesheet">
		<link href="/css/color-switcher-design.css" rel="stylesheet">

		<link href="/css/bootstrap.css" rel="stylesheet">
		<link href="/css/style.css" rel="stylesheet">
		<link href="/css/responsive.css" rel="stylesheet">
	</head>
	<body class="body-bg-color">
		<a href="#main-content" class="skip-link">Ir al contenido principal</a>
		<div class="page-wrapper">
			<Header />
			<slot />
		</div>
		
		<Footer />
	</body>
</html>
<style is:global>
	html {
		color-scheme: dark;
	}

	h1, h2, h3, h4, h5, h6 {
		text-wrap: balance;
	}

	p {
		text-wrap: pretty;
	}

	[id] {
		scroll-margin-top: 100px;
	}

	a, button {
		touch-action: manipulation;
	}

	.skip-link {
		position: absolute;
		top: -100%;
		left: 16px;
		z-index: 10000;
		padding: 8px 16px;
		background: var(--thm-base, #FF6C1E);
		color: #fff;
		border-radius: 4px;
		font-weight: 600;
		text-decoration: none;
	}

	.skip-link:focus {
		top: 16px;
	}

	:focus-visible {
		outline: 2px solid var(--thm-base, #FF6C1E) !important;
		outline-offset: 2px;
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
			scroll-behavior: auto !important;
		}
	}

	/* Restaurar colores de componentes sobre fondo oscuro */
	.team-one__name,
	.ai-product__title,
	.solutions-one__title {
		color: var(--thm-white);
	}

	.feature-one__icon h2 {
		font-size: 48px;
		line-height: 58px;
		margin: 0;
	}

	.solutions-one__icon h2 {
		font-size: 48px;
		line-height: 1;
		margin: 0;
	}

	/* Imágenes: reservar proporción sin forzar tamaño de render */
	img {
		max-width: 100%;
		height: auto;
	}

	.feature-one__start-1 img,
	.feature-one__start-2 img,
	.feature-one__start-3 img,
	.feature-one__start-4 img,
	.feature-one__start-5 img,
	.feature-one__start-6 img,
	.feature-one__start-7 img,
	.feature-one__start-8 img,
	.free-trail__start-1 img,
	.free-trail__start-2 img,
	.free-trail__start-3 img,
	.free-trail__start-4 img {
		width: auto;
		height: auto;
	}

	.ai-product__icon i {
		font-size: 56px;
		line-height: 1;
		color: var(--thm-base);
	}

	.faq-one {
		padding: 100px 0 120px;
	}

	.free-trail {
		padding-bottom: 60px;
	}

	.section-title {
		margin-bottom: 50px;
	}

	.solutions-two__content-one-points li .text p {
		color: var(--thm-gray);
	}

	h1.page-title__title,
	h2.page-title__title,
	h3.page-title__title {
		color: var(--thm-white);
	}
</style>
