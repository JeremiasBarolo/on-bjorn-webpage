---
import { faqs } from '../../data/faqs';
---

<section class="faq-one" id="faq">
    <div class="container">
        <div class="section-title text-center">
            <div class="section-title__tagline-box">
                <span class="section-title__tagline">Preguntas frecuentes</span>
            </div>
            <h2 class="section-title__title">¿Tenés alguna pregunta sobre <br> nuestros servicios?
            </h2>
        </div>
        <div class="faq-one__inner faq-one-accrodion">
            {faqs.map((faq) => (
                <div class="accrodion">
                    <h3 class="accrodion-heading">
                        <button type="button" class="accrodion-title" aria-expanded="false" aria-controls={`${faq.id}-content`} id={`${faq.id}-title`}>
                            {faq.pregunta}
                        </button>
                    </h3>
                    <div class="accrodion-content" id={`${faq.id}-content`} role="region" aria-labelledby={`${faq.id}-title`}>
                        <div class="inner">
                            <p set:html={faq.respuestaHtml} />
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const accrodionTitles = document.querySelectorAll(".accrodion-title");

        accrodionTitles.forEach(function (title) {
            title.addEventListener("click", function () {
                const accrodion = this.closest(".accrodion");
                const isActive = accrodion.classList.contains("active");
                const content = accrodion.querySelector(".accrodion-content");

                if (isActive) {
                    content.style.maxHeight = "0";
                    this.setAttribute("aria-expanded", "false");
                    setTimeout(function () {
                        accrodion.classList.remove("active");
                    }, 300);
                } else {
                    const activeAccordions = document.querySelectorAll(".faq-one-accrodion .accrodion.active");
                    activeAccordions.forEach(function (acc) {
                        const activeContent = acc.querySelector(".accrodion-content");
                        const activeTitle = acc.querySelector(".accrodion-title");
                        if (activeContent) activeContent.style.maxHeight = "0";
                        acc.classList.remove("active");
                        if (activeTitle) activeTitle.setAttribute("aria-expanded", "false");
                    });

                    accrodion.classList.add("active");
                    this.setAttribute("aria-expanded", "true");
                    content.style.maxHeight = content.scrollHeight + "px";
                }
            });
        });
    });
</script>

<style>
    /***
        Faq One
    ***/
    .faq-one {
        position: relative;
        display: block;
    }

    .faq-one .container {
        max-width: 875px;
    }

    .faq-one__inner {
        position: relative;
        display: block;
    }

    .faq-one-accrodion .accrodion {
        position: relative;
        display: block;
        background-color: var(--thm-main-bg);
        border: 1px solid var(--thm-bdr-color);
        border-radius: var(--thm-border-radius);
        transition: background-color 0.5s ease, border-color 0.5s ease;
    }

    .accrodion-heading {
        margin: 0;
    }

    .faq-one-accrodion .accrodion-title {
        position: relative;
        display: block;
        width: 100%;
        cursor: pointer;
        padding: 20px 30px 20px;
        padding-right: 50px;
        background: none;
        border: none;
        text-align: left;
        font-family: inherit;
        font-size: 20px;
        color: var(--thm-gray);
        font-weight: 500;
        line-height: 30px;
        transition: color 0.3s ease;
    }

    .faq-one-accrodion .accrodion.active .accrodion-title {
        color: var(--thm-white);
    }

    .faq-one-accrodion .accrodion+.accrodion {
        margin-top: 15px;
    }

    .faq-one-accrodion .accrodion-title::before {
        content: "\e901";
        font-family: 'icomoon' !important;
        font-size: 13px;
        color: var(--thm-gray);
        position: absolute;
        top: 50%;
        right: 25px;
        line-height: 15px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        transform: translateY(-50%);
        transition: color 0.3s ease, transform 0.3s ease;
        text-align: center;
        width: 21px;
        height: 21px;
    }

    .faq-one-accrodion .accrodion.active .accrodion-title::before {
        color: var(--thm-white);
        transform: translateY(-50%) rotate(-180deg);
    }

    .faq-one-accrodion .accrodion-content {
        position: relative;
        overflow: hidden;
        max-height: 0;
        transition: max-height 0.5s ease;
    }

    .faq-one-accrodion .accrodion-content p {
        margin: 0;
        padding-bottom: 2em;
        padding-right: 3em;
        padding-left: 4em;
    }

    .faq-one-accrodion .accrodion-content p :global(a) {
        color: var(--thm-gradient-color2);
    }

    @media (prefers-reduced-motion: reduce) {
        .faq-one-accrodion .accrodion,
        .faq-one-accrodion .accrodion-title,
        .faq-one-accrodion .accrodion-title::before,
        .faq-one-accrodion .accrodion-content {
            transition: none;
        }
    }
</style>
