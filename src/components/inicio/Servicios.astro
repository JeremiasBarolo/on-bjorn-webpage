---
import Card from '../shared/Card.astro'

---

<!-- Solutions One Start -->
<div class="solutions-one" id="services">
    <div class="container">


        <div class="section-title text-center">
            <div class="section-title__tagline-box">
                <span class="section-title__tagline">Servicios</span>
            </div>
            <h2 class="section-title__title"> Nuestros Servicios <br>
                Para Ayudar a tu Emprendimiento <span aria-hidden="true">🔨</span></h2>
        </div>


        <div class="solutions-one__carousel" id="service-carrousel" tabindex="0" role="region" aria-label="Carrusel de servicios">
            <div class="item active">
                <Card  
                icon='🌀'
                title='Desarrollo Web'
                content = 'Desarrollamos paginas web a medida para cada objetivo de nuestros clientes.'
                
                />
            </div>
            <div class="item">
                <Card  
                    icon='🎨'
                    title='Rebranding'
                    content='Transformamos la imagen de tu marca con un rebranding audaz y cautivador.'
                />
            </div>
            <div class="item">
                <Card  
                    icon='👟'
                    title='E-Commerce'
                    content='Creamos tu negocio online para exponer tus productos y potenciar tus ventas.'
                />
            </div>
            <div class="item">
                <Card  
                    icon='💼'
                    title='Web Empresariales'
                    content='Te ayudamos a dar el salto de calidad para profesionalizar tu empresa de forma online.'
                />
            </div>
            <div class="item">
                <Card  
                    icon='📑'
                    title='Portfolio Web Interactivo'
                    content='Creamos una web profesional para destacar tu trabajo especializado, dando énfasis en tu imagen.'
                />
            </div>
            <div class="item">
                <Card  
                    icon='📦'
                    title='Sistemas de Stock'
                    content='Desarrollamos tu sistema de stock hecho a medida para poder organizar tu emprendimiento.'
                />
            </div>
        </div>
    </div>
</div>

<style>
  
    #service-carrousel {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x proximity;
        -webkit-overflow-scrolling: touch;
        cursor: grab;
        scrollbar-width: thin;
        padding-bottom: 8px;
    }

    #service-carrousel.is-dragging {
        cursor: grabbing;
        user-select: none;
        scroll-snap-type: none;
    }

    .item {
        flex: 0 0 auto;
        width: calc(25% - 12px); /* Ajusta el ancho de cada elemento */
        margin-right: 24px; /* Margen entre elementos */
        scroll-snap-align: start;
    }

    .item:last-child {
        margin-right: 2em;
    }

    @media only screen and (max-width: 767px) {
        .item {
            width: calc(100% - 24px);
            max-width: 300px;
        }
    }
</style>

<script>
   document.addEventListener('DOMContentLoaded', function() {
    const carousel = document.getElementById('service-carrousel');
    if (!carousel) return;

    let isDragging = false;
    let startX = 0;
    let startScrollLeft = 0;

    // Arrastre con mouse; en táctil se usa el scroll nativo del navegador
    carousel.addEventListener('mousedown', e => {
        isDragging = true;
        startX = e.pageX;
        startScrollLeft = carousel.scrollLeft;
        carousel.classList.add('is-dragging');
    });

    ['mouseleave', 'mouseup'].forEach(evt => {
        carousel.addEventListener(evt, () => {
            isDragging = false;
            carousel.classList.remove('is-dragging');
        });
    });

    carousel.addEventListener('mousemove', e => {
        if (!isDragging) return;
        e.preventDefault();
        carousel.scrollLeft = startScrollLeft - (e.pageX - startX);
    });
});
</script>