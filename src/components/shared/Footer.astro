---
const currentYear = new Date().getFullYear();
---

    <footer class="main-footer">
        <div class="main-footer__shape-1 img-bounce"></div>
        <div class="main-footer__top">
            <div class="container">
                <div class="row">
                    <div class="col-xl-3 col-lg-6 col-md-6 wow fadeInUp" data-wow-delay="100ms">
                        <div class="footer-widget__column footer-widget__about">
                            <div class="footer-widget__logo">
                                <a href="/"><img src="/images/resource/marca-de-agua.png" alt="ON Bjorn — Inicio" loading="lazy"></a>
                            </div>
                            <p class="footer-widget__about-text">Te ayudamos a dar el paso de calidad que tu emprendimiento necesita.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="main-footer__bottom">
            <div class="container">
                <div class="main-footer__bottom-inner">
                    <p class="main-footer__bottom-text">Copyright © {currentYear} <a href="https://www.instagram.com/on_bjorn/" target="_blank" rel="noopener noreferrer">ON BJORN</a>. Todos los derechos reservados.</p>
                </div>
            </div>
        </div>
    </footer>