---
interface Props {
    icon: string;
    title: string;
    content: string;
}
const {icon, title, content} = Astro.props;

---


<div class="solutions-one__single">
    <div class="solutions-one__icon">
        <h2 aria-hidden="true">{icon}</h2>
    </div>
    <h4 class="solutions-one__title">{title}</h4>
    <p class="solutions-one__text">
        {content}
    </p>
</div>


<style>
   .solutions-one__text {
    white-space: normal;
}
</style>
