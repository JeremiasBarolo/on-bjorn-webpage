{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DeployToS3",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::onbjorn-web-prod",
        "arn:aws:s3:::onbjorn-web-prod/*"
      ]
    },
    {
      "Sid": "InvalidateCloudFront",
      "Effect": "Allow",
      "Action": "cloudfront:CreateInvalidation",
      "Resource": "arn:aws:cloudfront::*:distribution/E1LJWEGQBQ9HS"
    }
  ]
}
